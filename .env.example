# =================================================
#  Knowledge RAG Configuration
# =================================================

# Platform (only douyin for now)
PROVIDER=douyin

# ── LLM Configuration ──────────────────────────
# Supports any OpenAI-compatible API (DeepSeek, DashScope, etc.)
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
# 必填：填入你的 API Key
LLM_API_KEY=sk-your-api-key-here

# ── Embedding ──────────────────────────────────
# local: 使用本地 sentence-transformers 模型（BGE-small-zh，约400MB）
# dashscope: 使用阿里云百炼 API
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── Speech-to-Text (ASR) ───────────────────────
# local: 使用本地 faster-whisper 模型
# dashscope: 使用阿里云百炼 API
ASR_PROVIDER=local
ASR_MODEL=base

# ── Vector Store ───────────────────────────────
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# ── Database ───────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge_rag.db

# ── Retrieval ──────────────────────────────────
RETRIEVAL_TOP_K=8
RETRIEVAL_MMR_FETCH_K=32
RETRIEVAL_MMR_LAMBDA=0.55

# ── Chunking ───────────────────────────────────
CHUNK_STRATEGY=semantic
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Worker ─────────────────────────────────────
WORKER_CONCURRENCY=2

# ── Server ─────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Network (中国大陆用户必填) ─────────────────
# 使用 HuggingFace 镜像加速模型下载
HF_ENDPOINT=https://hf-mirror.com

# ── PyPI Mirror (中国大陆用户选填) ────────────
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
