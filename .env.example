# =================================================
#  Knowledge RAG Configuration
# =================================================

# Platform (only douyin for now)
PROVIDER=douyin

# 鈹€鈹€ LLM Configuration 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
# Supports any OpenAI-compatible API (DeepSeek, DashScope, etc.)
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
# 蹇呭～锛氬～鍏ヤ綘鐨?API Key
LLM_API_KEY=YOUR_API_KEY_HERE

# 鈹€鈹€ Embedding 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
# local: 浣跨敤鏈湴 sentence-transformers 妯″瀷锛圔GE-small-zh锛岀害400MB锛?# dashscope: 浣跨敤闃块噷浜戠櫨鐐?API
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 鈹€鈹€ Speech-to-Text (ASR) 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
# local: 浣跨敤鏈湴 faster-whisper 妯″瀷
# dashscope: 浣跨敤闃块噷浜戠櫨鐐?API
ASR_PROVIDER=local
ASR_MODEL=base

# 鈹€鈹€ Vector Store 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 鈹€鈹€ Database 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge_rag.db

# 鈹€鈹€ Retrieval 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
RETRIEVAL_TOP_K=8
RETRIEVAL_MMR_FETCH_K=32
RETRIEVAL_MMR_LAMBDA=0.55

# 鈹€鈹€ Chunking 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
CHUNK_STRATEGY=semantic
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# 鈹€鈹€ Worker 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
WORKER_CONCURRENCY=2

# 鈹€鈹€ Server 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# 鈹€鈹€ Network (涓浗澶ч檰鐢ㄦ埛蹇呭～) 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
# 浣跨敤 HuggingFace 闀滃儚鍔犻€熸ā鍨嬩笅杞?HF_ENDPOINT=https://hf-mirror.com

